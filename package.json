{
  "name": "@nplus-father/notes-core",
  "version": "0.2.0",
  "description": "技術筆記星系（nplus.wiki）Astro 筆記站的共用核心：withBase、複習紀錄 factory、remark-details 外掛、設計 token、Stars 元件。",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nplus-father/notes-core.git"
  },
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./sites": "./src/lib/sites.ts",
    "./remark-details": "./src/plugins/remark-details.mjs",
    "./remark-response": "./src/plugins/remark-response.mjs",
    "./styles/tokens.scss": "./src/styles/tokens.scss",
    "./styles/two-block.scss": "./src/styles/two-block.scss",
    "./Stars.astro": "./src/components/Stars.astro",
    "./SourceByline.astro": "./src/components/SourceByline.astro",
    "./Bookshelf.astro": "./src/components/Bookshelf.astro"
  },
  "sideEffects": [
    "*.scss"
  ],
  "dependencies": {
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "astro": ">=5"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
