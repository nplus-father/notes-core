---
// 首頁「參考書架」：一眼看出本站彙整自哪些 owned books（書的歸屬放首頁，
// 各主題頁內文就不必逐段標書名）。books 由各站 src/data/books.ts 提供。
import { bookUrl } from "../lib/links";
interface Book {
  slug: string;
  title: string;
}
interface Props {
  books: Book[];
  heading?: string;
  note?: string;
}
const {
  books,
  heading = "📚 本站彙整自這些書",
  note = "內容以這些線上書為源，逐頁溯源",
} = Astro.props;
---

{
  books.length > 0 && (
    <section class="bookshelf">
      <div class="bookshelf-head">
        <h2>{heading}</h2>
        <span class="bookshelf-note">{note}</span>
      </div>
      <div class="cover-row">
        {books.map((b) => (
          <a
            class="cover-item"
            href={bookUrl(b.slug)}
            target="_blank"
            rel="noopener"
            title={b.title}
          >
            <img
              class="cover-img"
              src={bookUrl(b.slug, "cover.png")}
              alt={b.title}
              loading="lazy"
              width="132"
              height="190"
            />
            <span class="cover-cap">{b.title}</span>
          </a>
        ))}
      </div>
    </section>
  )
}
