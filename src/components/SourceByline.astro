---
// 頁首優雅的來源 byline：把 furtherReading 的書名低調列在標題下，
// 不在內文逐段標「出自哪本書哪章」。完整章節清單見頁尾「內容來源」。
import { bookUrl } from "../lib/links";
interface Item {
  book: string;
  label: string;
  anchor?: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
const books = [...new Map(items.map((it) => [it.book, it])).values()];
const bookName = (label: string) => label.split(/[—–-]/)[0].trim();
---

{
  books.length > 0 && (
    <p class="source-byline">
      <span class="byline-mark">⟢</span> From
      {books.map((it, i) => (
        <>
          {i > 0 && <span class="byline-sep">·</span>}
          <a href={bookUrl(it.book, it.anchor)} target="_blank" rel="noopener">
            {bookName(it.label)}
          </a>
        </>
      ))}
    </p>
  )
}
