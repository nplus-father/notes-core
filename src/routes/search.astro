---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/url";
import { site } from "virtual:notes-core/site";

// Pagefind 資源在 build 後輸出到 <base>/pagefind/。base 路徑要一起帶上。
const pagefindUiCss = withBase("pagefind/pagefind-ui.css");
const pagefindUiJs = withBase("pagefind/pagefind-ui.js");
const bundlePath = withBase("pagefind/");
const placeholder = site.searchPlaceholder ?? "Search notes…";
const searchLede = site.searchLede ? site.searchLede.replaceAll("{base}", withBase("/")) : "";
---

<BaseLayout title={`Search · ${site.brand}`} site={site}>
  <header class="page-head">
    <h1>Search</h1>
    {
      searchLede ? (
        <p class="lede" set:html={searchLede} />
      ) : (
        <p class="lede">Search the full <strong>text</strong> of every page. Use the filters to narrow by category.</p>
      )
    }
  </header>

  <div id="search" class="pf-search"></div>

  <p id="pf-fallback" class="muted" hidden>
    Search index not built yet. It's generated during <code>npm run build</code> — run
    <code>npm run build &amp;&amp; npm run preview</code> to browse this page (<code>astro dev</code> doesn't load the index).
  </p>

  <link href={pagefindUiCss} rel="stylesheet" />
  <script is:inline src={pagefindUiJs}></script>
  <script define:vars={{ bundlePath, placeholder }}>
    window.addEventListener("DOMContentLoaded", () => {
      if (typeof PagefindUI === "undefined") {
        document.getElementById("pf-fallback")?.removeAttribute("hidden");
        return;
      }
      new PagefindUI({
        element: "#search",
        bundlePath,
        showSubResults: true,
        showImages: false,
        pageSize: 8,
        excerptLength: 24,
        translations: {
          placeholder,
          clear_search: "Clear",
          load_more: "Load more results",
          search_label: "Search notes",
          filters_label: "Filters",
          zero_results: "No results for [SEARCH_TERM]",
          many_results: "[COUNT] results for [SEARCH_TERM]",
          one_result: "[COUNT] result for [SEARCH_TERM]",
          alt_search: "No results for [SEARCH_TERM]; showing results for [DIFFERENT_TERM] instead",
          search_suggestion: "No results for [SEARCH_TERM]. Try one of these:",
          searching: "Searching [SEARCH_TERM]…",
        },
      });
    });
  </script>
</BaseLayout>
