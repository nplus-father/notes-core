---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/url";
import { site } from "virtual:notes-core/site";
const conceptLabel = site.conceptLabelEn ?? "Concepts";
const problemLabel = site.problemLabelEn ?? "Problems";
const lede = site.hasProblems
  ? "This page doesn't exist. Head home to browse concepts or problems, or use search."
  : "This page doesn't exist. Head home to start over, or use search.";
---

<BaseLayout title={`Not found · ${site.brand}`} site={site}>
  <section class="notfound">
    <p class="nf-code">404</p>
    <h1>This page isn't here — or the URL is off</h1>
    <p class="lede">{lede}</p>
    <p class="nf-actions">
      <a class="nf-btn" href={withBase("/")}>← Home</a>
      <a class="nf-btn" href={withBase("/concepts/")}>Browse {conceptLabel}</a>
      {site.hasProblems && <a class="nf-btn" href={withBase("/problems/")}>Browse {problemLabel}</a>}
      <a class="nf-btn" href={withBase("/search/")}>🔍 Search</a>
    </p>
  </section>
</BaseLayout>
