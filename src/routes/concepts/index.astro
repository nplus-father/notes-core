---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/url";
import { bareSlug } from "../../lib/collections";
import { site } from "virtual:notes-core/site";
import { getCategories } from "../../lib/nav-data";
import { getCollection } from "astro:content";

const concepts = await getCollection("concepts");
const { categories, roadmap } = await getCategories();
// chrome 統一英文；標籤與 topnav 的 Concepts 項一致（語意站用 conceptLabelEn，如 Patterns）。
const conceptLabel = site.conceptLabelEn ?? "Concepts";
const hasSister = categories.some((c: any) => c.sister);

// 依分類建 bareSlug → 已寫頁 的索引（collection id 形如 "naming/intention-revealing-names"）
const writtenByCat = new Map<string, Map<string, (typeof concepts)[number]>>();
for (const c of concepts) {
  const cat = c.data.category;
  if (!writtenByCat.has(cat)) writtenByCat.set(cat, new Map());
  writtenByCat.get(cat)!.set(bareSlug(c.id), c);
}

const cats = [...categories].sort((a: any, b: any) => a.order - b.order);

// 每個分類：只收「已成頁」的 roadmap 節點（待寫節點不再顯示），依 tier 分成兩條 lane。
// 只有基礎/進階兩步，故用兩條標示清楚的 lane 呈現（取代會因字數換行錯位的單列 rail）。
const tracks = cats
  .map((c: any) => {
    const nodes = ((roadmap as any)[c.slug] ?? [])
      .map((n: any) => {
        const entry = writtenByCat.get(c.slug)?.get(n.slug);
        return entry
          ? { title: entry.data.title, tier: n.tier, href: withBase(`concepts/${entry.id}/`) }
          : null;
      })
      .filter(Boolean);
    return {
      cat: c,
      basic: nodes.filter((n: any) => n.tier === "basic"),
      advanced: nodes.filter((n: any) => n.tier === "advanced"),
    };
  })
  .filter((t: any) => t.basic.length + t.advanced.length > 0);
---

<BaseLayout title={`${conceptLabel} · ${site.brand}`} site={site}>
  <nav class="crumbs"><a href={withBase("/")}>Home</a><span>/</span><span>{conceptLabel}</span></nav>
  <header class="page-head">
    <h1>📚 {conceptLabel}</h1>
    <p class="lede">
      Each track runs <strong>Basic → Advanced</strong>.
      {hasSister && <> Tracks marked ↘ dive deeper into a sister site.</>}
    </p>
  </header>

  <section class="tracks">
    {
      tracks.map(({ cat, basic, advanced }: any) => (
        <article class="track">
          <div class="track-head">
            <span class="track-icon">{cat.icon}</span>
            <a class="track-name" href={withBase(`concepts/${cat.slug}/`)}>
              {cat.name}
            </a>
            {cat.sister && (
              <span class="deep-tag" title={`Dive deeper → ${cat.sister}`}>
                ↘ {cat.sister}
              </span>
            )}
          </div>

          <div class="rail">
            {basic.length > 0 && (
              <div class="lane">
                <span class="lane-label">Basic</span>
                <div class="lane-nodes">
                  {basic.map((n: any) => (
                    <a class="node done" href={n.href}>
                      <span class="node-dot" />
                      {n.title}
                    </a>
                  ))}
                </div>
              </div>
            )}
            {advanced.length > 0 && (
              <div class="lane">
                <span class="lane-label adv">Advanced</span>
                <div class="lane-nodes">
                  {advanced.map((n: any) => (
                    <a class="node done" href={n.href}>
                      <span class="node-dot" />
                      {n.title}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>
