---
import BaseLayout from "../layouts/BaseLayout.astro";
import Bookshelf from "../components/Bookshelf.astro";
import { withBase } from "../lib/url";
import { site, books } from "virtual:notes-core/site";
import { getCategories } from "../lib/nav-data";
import { getCollection } from "astro:content";

const concepts = await getCollection("concepts");
const conceptCount = new Map<string, number>();
for (const c of concepts)
  conceptCount.set(c.data.category, (conceptCount.get(c.data.category) ?? 0) + 1);

const { categories: cats } = await getCategories();
const conceptLabel = site.conceptLabel ?? "概念";
// prose config 可用 {base} 代表站台 base 前綴（withBase("/")），供含站內連結的文案使用。
const heroLede = (site.heroLede ?? "").replaceAll("{base}", withBase("/"));
---

<BaseLayout title={site.tagline ? `${site.brand} · ${site.tagline}` : site.brand} site={site}>
  <header class="home-hero">
    <img class="site-cover" src={withBase("cover.svg")} alt={site.brand} width="480" height="252" />
    <div class="home-hero-body">
      <h1>{site.brand}</h1>
      {heroLede && <p class="lede" set:html={heroLede} />}
    </div>
  </header>

  <Bookshelf books={books} />

  {
    site.homeShowCategories && (
      <section class="home-section">
        <div class="home-section-head">
          <h2>📚 {conceptLabel}</h2>
          <a class="see-all" href={withBase("/concepts/")}>
            看全部 →
          </a>
        </div>
        <div class="cat-grid">
          {cats.map((c: any) => (
            <a class="cat-card" href={withBase(`concepts/${c.slug}/`)}>
              <span class="cat-icon">{c.icon}</span>
              <span class="cat-body">
                <span class="cat-name">{c.name}</span>
                <span class="cat-intro">{c.intro}</span>
              </span>
              <span class="cat-count">{conceptCount.get(c.slug) ?? 0}</span>
            </a>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
