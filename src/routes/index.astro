---
import BaseLayout from "../layouts/BaseLayout.astro";
import Bookshelf from "../components/Bookshelf.astro";
import { withBase } from "../lib/url";
import { site, books } from "virtual:notes-core/site";

// 首頁只有 hero（品牌 + 導言）＋ 參考書架（Sources）。概念入口走 topnav 的 Concepts，
// 不在首頁重複分類格——避免與 /concepts/ 學習路徑頁重覆。
// prose config 可用 {base} 代表站台 base 前綴（withBase("/")）。
const heroLede = (site.heroLede ?? "").replaceAll("{base}", withBase("/"));
---

<BaseLayout title={site.tagline ? `${site.brand} · ${site.tagline}` : site.brand} site={site}>
  <header class="home-hero">
    <img class="site-cover" src={withBase("cover.svg")} alt={site.brand} width="480" height="252" />
    <div class="home-hero-body">
      <h1>{site.brand}</h1>
      {heroLede && <p class="lede" set:html={heroLede} />}
    </div>
  </header>

  <Bookshelf books={books} />
</BaseLayout>
